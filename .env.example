# ============================================================
# RecruiterAI — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ============================================================
# APPLICATION
# ============================================================
APP_NAME=RecruiterAI
APP_ENV=development                    # development | staging | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-to-random-string

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=recruiterai
POSTGRES_USER=recruiterai
POSTGRES_PASSWORD=change-me

# ============================================================
# SOURCES — Welche Datenquellen sind aktiv?
# Setze auf true/false um einzelne Sources zu aktivieren/deaktivieren.
# Wenn eine Source deaktiviert ist, werden deren Konfigurationsfelder ignoriert.
# ============================================================
SOURCE_EMAIL_ENABLED=true
SOURCE_LINKEDIN_ENABLED=false
SOURCE_EXTERNAL_API_ENABLED=false

# ============================================================
# EMAIL SOURCE — IMAP (Outlook/Exchange oder beliebiger Provider)
# Nur erforderlich wenn SOURCE_EMAIL_ENABLED=true
# ============================================================
EMAIL_PROTOCOL=imap                    # imap | graph_api
EMAIL_IMAP_HOST=outlook.office365.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=recruiting@example.ch
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_USE_SSL=true
EMAIL_POLL_INTERVAL_SECONDS=60
EMAIL_INBOX_FOLDER=INBOX

# SMTP for sending follow-up mails
EMAIL_SMTP_HOST=smtp.office365.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=recruiting@example.ch
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=true
EMAIL_FROM_ADDRESS=recruiting@example.ch
EMAIL_FROM_NAME=RecruiterAI

# Microsoft Graph API (Alternative zu IMAP)
# Nur erforderlich wenn EMAIL_PROTOCOL=graph_api
EMAIL_GRAPH_TENANT_ID=
EMAIL_GRAPH_CLIENT_ID=
EMAIL_GRAPH_CLIENT_SECRET=
EMAIL_GRAPH_USER_EMAIL=recruiting@example.ch

# ============================================================
# LINKEDIN SOURCE
# Nur erforderlich wenn SOURCE_LINKEDIN_ENABLED=true
# ============================================================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_COMPANY_ID=
LINKEDIN_POLL_INTERVAL_SECONDS=300

# ============================================================
# EXTERNAL REST API — Anbindung an Kunden-Webapp
# Nur erforderlich wenn SOURCE_EXTERNAL_API_ENABLED=true
# Alle Endpoints sind konfigurierbar damit es mit jeder REST API funktioniert.
# ============================================================
EXTERNAL_API_BASE_URL=https://app.kunde.ch/api/v1
EXTERNAL_API_AUTH_TYPE=bearer           # bearer | basic | api_key | none
EXTERNAL_API_AUTH_TOKEN=
EXTERNAL_API_AUTH_USER=
EXTERNAL_API_AUTH_PASSWORD=
EXTERNAL_API_KEY_HEADER=X-API-Key
EXTERNAL_API_KEY_VALUE=

# Endpoint-Pfade (relativ zur BASE_URL)
EXTERNAL_API_CANDIDATES_GET=/candidates
EXTERNAL_API_CANDIDATES_POST=/candidates
EXTERNAL_API_CANDIDATES_PUT=/candidates/{id}
EXTERNAL_API_JOBS_GET=/jobs
EXTERNAL_API_JOBS_POST=/jobs
EXTERNAL_API_MATCHES_GET=/matches
EXTERNAL_API_MATCHES_POST=/matches

# ============================================================
# TWILIO — Telefonie
# ============================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+41XXXXXXXXX       # Schweizer Nummer
TWILIO_WEBHOOK_BASE_URL=https://your-domain.ch  # Für Twilio Callbacks
TWILIO_STATUS_CALLBACK_URL=             # Optional: /api/webhooks/twilio/status

# ============================================================
# ELEVENLABS — Text-to-Speech
# ============================================================
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_DE=                 # Deutsche Stimme
ELEVENLABS_VOICE_ID_EN=                 # Englische Stimme
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# ============================================================
# DEEPGRAM — Speech-to-Text
# ============================================================
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE_DETECT=true           # Auto Sprach-Erkennung DE/EN

# ============================================================
# ANTHROPIC — Claude API (LLM / Konversationslogik)
# ============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# ============================================================
# MATCHING — Konfiguration
# ============================================================
MATCH_THRESHOLD_PERCENT=80              # Ab wann anrufen
MATCH_AUTO_CALL_ENABLED=true            # Automatisch anrufen bei Match
MATCH_AUTO_EMAIL_FOLLOWUP=true          # Automatisch Retour-Mail bei fehlenden Infos
MATCH_MISSING_INFO_FIELDS=skills,experience_years,salary_expectation,availability,location

# CRM "NOT NULL" / required set: if any of these is missing after CV parsing,
# the candidate goes into INFO_REQUESTED status and gets a follow-up mail.
CRM_REQUIRED_FIELDS=first_name,last_name,email,phone
# Where uploaded CV files live inside the backend container.
CV_STORAGE_DIR=/data/cv

# ============================================================
# AGENT IDENTITY
# ============================================================
AGENT_NAME=Lara
COMPANY_NAME=RecruiterAI Schweiz

# ============================================================
# FRONTEND
# ============================================================
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
